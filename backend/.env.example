PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
SESSION_SECRET="your_long_random_session_secret"
CLIENT_ORIGIN="http://localhost:5173"
SOCKET_ORIGIN="http://localhost:5173"
REDIS_URL="redis://localhost:6379"

# GitHub OAuth
GITHUB_CLIENT_ID="your_client_id"
GITHUB_CLIENT_SECRET="your_client_secret"
GITHUB_CALLBACK_URL="http://localhost:4000/api/github/callback"

# Auth & JWT (RS256)
# Generate keys with: openssl genrsa -out private.pem 2048; openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_B64="base64_encoded_private_key"
JWT_PUBLIC_KEY_B64="base64_encoded_public_key"
SESSION_SECRET="your_fallback_hmac_secret_for_legacy"

# S3 / MinIO (For time-travel snapshots)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="devcollab-snapshots"
S3_REGION="us-east-1"
S3_USE_SSL="false"

# WebRTC (Signaling & TURN)
TURN_URL="turn:your_turn_server:3478"
TURN_USERNAME="user"
TURN_CREDENTIAL="password"

# Observability (OpenTelemetry)
OTEL_SERVICE_NAME="devcollab-backend"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"

